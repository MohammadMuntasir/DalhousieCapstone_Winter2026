/*========================================================
  /action endpoint
========================================================*/
void handleAction() {
  if (!server.hasArg("cmd")) {
    server.send(400, "text/plain", "Missing cmd");
    return;
  }

  String cmd = server.arg("cmd");

  if (cmd == "constBase") {
    H_sensor_const = readDistanceCm(100);
    H_500 = NAN;
    H_1000 = NAN;
    volumeConstant = NAN;
    server.send(200, "text/plain", isnan(H_sensor_const) ? "FAIL" : "OK");
    return;
  }

  if (cmd == "cal500") {
    if (isnan(H_sensor_const)) {
      server.send(400, "text/plain", "Read constant base first");
      return;
    }
    H_500 = readDistanceCm(100);
    server.send(200, "text/plain", isnan(H_500) ? "FAIL" : "OK");
    return;
  }

  if (cmd == "cal1000") {
    if (isnan(H_sensor_const) || isnan(H_500)) {
      server.send(400, "text/plain", "Do constant base + 500 mL first");
      return;
    }
    H_1000 = readDistanceCm(100);

    if (!isnan(H_1000)) {
      float height_500 = H_sensor_const - H_500;
      float height_1000 = H_sensor_const - H_1000;
      if (height_500 != 0) {
        volumeConstant = height_1000 / height_500;
      }
    }

    server.send(200, "text/plain", (isnan(H_1000) || isnan(volumeConstant)) ? "FAIL" : "OK");
    return;
  }

  if (cmd == "setConstant") {
    if (!server.hasArg("value")) {
      server.send(400, "text/plain", "Missing value");
      return;
    }

    float val = server.arg("value").toFloat();
    if (val <= 0) {
      server.send(400, "text/plain", "Invalid constant");
      return;
    }

    volumeConstant = val;
    server.send(200, "text/plain", "OK");
    return;
  }

  if (cmd == "base") {
    H_sensor = readDistanceCm(100);
    H_o = NAN;
    H_d = NAN;
    rise = NAN;
    totalHeight = NAN;
    experimentRunning = false;
    alarmTriggered = false;
    alarmEmailSent = false;

    server.send(200, "text/plain", isnan(H_sensor) ? "FAIL" : "OK");
    return;
  }

  if (cmd == "surface") {
    if (isnan(H_sensor)) {
      server.send(400, "text/plain", "Read experiment base first");
      return;
    }

    H_o = readDistanceCm(100);
    if (!isnan(H_o)) {
      H_d = H_sensor - H_o;
      rise = 0;
      totalHeight = H_d;
    }

    experimentRunning = false;
    alarmTriggered = false;
    alarmEmailSent = false;

    server.send(200, "text/plain", isnan(H_o) ? "FAIL" : "OK");
    return;
  }

  if (cmd == "start") {
    if (isnan(H_sensor) || isnan(H_o) || isnan(H_d) || isnan(volumeConstant)) {
      server.send(400, "text/plain", "Do experiment base + surface + constant first");
      return;
    }

    alarmTriggered = false;
    alarmEmailSent = false;
    experimentRunning = true;
    lastUpdate = 0;
    server.send(200, "text/plain", "OK");
    return;
  }

  if (cmd == "stop") {
    experimentRunning = false;
    server.send(200, "text/plain", "OK");
    return;
  }

  if (cmd == "resetAlarm") {
    alarmTriggered = false;
    alarmEmailSent = false;
    server.send(200, "text/plain", "OK");
    return;
  }

  server.send(400, "text/plain", "Unknown cmd");
}

