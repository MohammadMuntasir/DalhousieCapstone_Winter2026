/* ========================================================
   Time / NTP helpers
   ======================================================== */
String getFormattedDateTime() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) {
    return "0000-00-00 00:00:00";
  }
  char buf[25];
  strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", &timeinfo);
  return String(buf);
}

unsigned long getTimeStamp() {
  time_t now;
  struct tm timeinfo;

  if (!getLocalTime(&timeinfo)) {
    return 0;
  }

  time(&now);
  return (unsigned long)now;
}

/*========================================================
  Ultrasonic readDistanceCm
========================================================*/
float readDistanceCm(int samples) {
  float sum = 0;
  int validsamples = 0;
  float distance;
  for (int i = 0; i < samples; i++) {
    digitalWrite(trigPin, LOW);
    delayMicroseconds(2);
    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);

    long duration = pulseIn(echoPin, HIGH, 30000);
    if (duration > 0) {
      sum += duration;
      validsamples++;
    }
    delay(20);
  }
  if (validsamples == 0) {
    return NAN;
  }
  distance = (sum / validsamples) * Sound_speed / 2.0;
  return distance;
}

/*========================================================
  Experiment update
========================================================*/
void updateExperiment() {
  if (!experimentRunning) return;
  if (millis() - lastUpdate < UPDATE_MS) return;
  lastUpdate = millis();

  currentDistance = readDistanceCm(10);
  if (isnan(currentDistance) || isnan(H_o) || isnan(H_d) || isnan(volumeConstant)) return;

  rise = H_o - currentDistance;
  totalHeight = rise + H_d;

  float target = volumeConstant * H_d;

  if (fabs(totalHeight - target) < 0.5) {
    if (!alarmTriggered) {
      alarmTriggered = true;

      if (!alarmEmailSent) {
        sendRequested = true;
        alarmEmailSent = true;
        lastStatus = "Email queued…";
      }
    }
  }
}

/* ========================================================
   SD card functions
   ======================================================== */
void appendFile(fs::FS& fs, const char* path, const char* message) {
  File file = fs.open(path, FILE_APPEND);
  if (!file) return;
  file.print(message);
  file.close();
}

void ensureLogHeader() {
  if (!sdReady) return;
  if (!SD.exists(LOG_PATH)) {
    File file = SD.open(LOG_PATH, FILE_WRITE);
    if (file) {
      file.println("Timestamp,TemperatureC,HumidityPct,TotalHeightCm,InitialHeightCm");
      file.close();
    }
  }
}

void logBreadData(float temperature, float humidity) {
  if (!sdReady) return;
  if (isnan(temperature) || isnan(humidity)) return;

  String ts = getFormattedDateTime();

  String line = ts + "," +
                String(temperature, 1) + "," +
                String(humidity, 1) + ",";

  if (!isnan(totalHeight)) line += String(totalHeight, 2);
  else                     line += "";

  line += ",";

  if (!isnan(H_d)) line += String(H_d, 2);
  else             line += "";

  line += "\n";
  appendFile(SD, LOG_PATH, line.c_str());
}

/* ========================================================
   Firebase sender
   ======================================================== */
void sendToFirebase(float temperature, float humidity) {
  if (WiFi.status() != WL_CONNECTED) return;
  if (isnan(temperature) || isnan(humidity)) return;

  unsigned long timestamp = getTimeStamp();
  if (timestamp == 0) return;

  String json = "{";
  json += "\"temperature\":" + String(temperature, 1) + ",";
  json += "\"humidity\":" + String(humidity, 1) + ",";
  json += "\"timestamp\":" + String(timestamp) + ",";

  if (!isnan(totalHeight)) json += "\"totalHeight\":" + String(totalHeight, 2) + ",";
  else                     json += "\"totalHeight\":null,";

  if (!isnan(H_d)) json += "\"initialHeight\":" + String(H_d, 2) + ",";
  else             json += "\"initialHeight\":null,";

  if (!isnan(H_sensor)) json += "\"H_sensor\":" + String(H_sensor, 2) + ",";
  else                  json += "\"H_sensor\":null,";

  if (!isnan(H_o)) json += "\"H_o\":" + String(H_o, 2) + ",";
  else             json += "\"H_o\":null,";

  if (!isnan(H_d)) json += "\"H_d\":" + String(H_d, 2) + ",";
  else             json += "\"H_d\":null,";

  if (!isnan(volumeConstant)) json += "\"constant\":" + String(volumeConstant, 4) + ",";
  else                        json += "\"constant\":null,";

  json += "\"running\":";
  json += (experimentRunning ? "true" : "false");
  json += ",";

  json += "\"alarm\":";
  json += (alarmTriggered ? "true" : "false");

  json += "}";

  String path = String(firebaseHost) + "/breadMonitor/" + String(timestamp) + ".json";

  HTTPClient http;
  http.begin(firebaseClient, path);
  http.addHeader("Content-Type", "application/json");
  http.PUT(json);
  http.end();
}

/* ========================================================
   CSV download + clear
   ======================================================== */
void handleDownloadCSV() {
  if (!sdReady) {
    server.send(500, "text/plain", "SD not ready");
    return;
  }
  if (!SD.exists(LOG_PATH)) {
    server.send(404, "text/plain", "Log file not found");
    return;
  }

  File file = SD.open(LOG_PATH, FILE_READ);
  if (!file) {
    server.send(500, "text/plain", "Failed to open log");
    return;
  }

  server.sendHeader("Content-Type", "text/csv");
  server.sendHeader("Content-Disposition", "attachment; filename=\"fermentation_log.csv\"");
  server.sendHeader("Connection", "close");
  server.streamFile(file, "text/csv");
  file.close();
}

void handleClearCSV() {
  if (!sdReady) {
    server.send(500, "text/plain", "SD not ready");
    return;
  }
  if (SD.exists(LOG_PATH)) SD.remove(LOG_PATH);
  ensureLogHeader();
  server.send(200, "text/plain", "OK");
}

/* ========================================================
   Email functions
   ======================================================== */
void smtpCallback(SMTP_Status status) {
  if (status.success()) lastStatus = "Email sent";
  else                  lastStatus = "Email failed";
}

bool sendEmailNow(const String& subject, const String& bodyText) {
  if (recipientEmail.length() < 6 || recipientEmail.indexOf('@') < 1 || recipientEmail.indexOf('.') < 3) {
    lastStatus = "Set a valid recipient email first";
    return false;
  }

  session.server.host_name = SMTP_HOST;
  session.server.port = SMTP_PORT;
  session.login.email = AUTHOR_EMAIL;
  session.login.password = AUTHOR_APP_PASS;
  session.login.user_domain = "";

  message.clear();
  message.sender.name = "Bread Rising Monitor";
  message.sender.email = AUTHOR_EMAIL;
  message.subject = subject;
  message.addRecipient("User", recipientEmail.c_str());

  message.text.content = bodyText.c_str();
  message.text.charSet = "utf-8";
  message.text.transfer_encoding = Content_Transfer_Encoding::enc_7bit;

  smtp.callback(smtpCallback);

  if (!smtp.connect(&session)) {
    lastStatus = "SMTP connect failed";
    smtp.closeSession();
    return false;
  }

  bool ok = MailClient.sendMail(&smtp, &message);
  smtp.closeSession();

  lastStatus = ok ? "Email sent" : "Send failed";
  return ok;
}

