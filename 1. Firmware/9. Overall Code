)rawliteral";

  server.send(200, "text/html", html);
}

void handleNotFound() {
  server.send(404, "text/plain", "Page not found");
}

/*========================================================
  Setup / Loop
========================================================*/
void setup() {
  WiFiManager wm;
  bool connect = wm.autoConnect("BreadMonitorSetup");
  if (!connect) {
    ESP.restart();
  }

  MDNS.begin("breadmonitor");

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  dht.begin();

  sdReady = SD.begin();
  if (sdReady) {
    ensureLogHeader();
  }

  if (WiFi.status() == WL_CONNECTED) {
    configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
    struct tm timeinfo;
    timeReady = getLocalTime(&timeinfo);
  }

  firebaseClient.setInsecure();

  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.on("/action", handleAction);
  server.onNotFound(handleNotFound);

  server.on("/status", HTTP_GET, handleStatus);
  server.on("/notify", HTTP_POST, handleNotify);
  server.on("/setRecipient", HTTP_GET, handleSetRecipient);

  server.on("/download", HTTP_GET, handleDownloadCSV);
  server.on("/clearlog", HTTP_POST, handleClearCSV);

  server.begin();

  lastLog = millis();
  lastFirebaseSend = millis();
}

void loop() {
  server.handleClient();
  updateExperiment();

  unsigned long now = millis();

  if (now - lastLog >= LOG_INTERVAL_MS) {
    float h = dht.readHumidity();
    float t = dht.readTemperature();
    logBreadData(t, h);
    lastLog = now;
  }

  if (now - lastFirebaseSend >= FIREBASE_INTERVAL_MS) {
    float h = dht.readHumidity();
    float t = dht.readTemperature();
    sendToFirebase(t, h);
    lastFirebaseSend = now;
  }

  if (sendRequested) {
    sendRequested = false;

    String subject = "BreadMonitor: Sourdough Doubled";
    String body =
      "Sourdough has approximately doubled in Volume.\n\n"
      "Current total height (cm): " + String(totalHeight) + "\n"
      "Initial Height (cm): " + String(H_d) + "\n"
      "Constant: " + String(volumeConstant, 4) + "\n";

    sendEmailNow(subject, body);
  }
}
