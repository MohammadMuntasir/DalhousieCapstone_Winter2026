// 404 handler
void handleNotFound() {
  server.send(404, "text/plain", "Page not found");  // Send 404 message
}

// Setup
void setup() {
  WiFiManager wm;                                      // Create WiFi manager
  bool connect = wm.autoConnect("BreadMonitorSetup"); // Start captive portal
  if (!connect) {                                     // If WiFi fails
    ESP.restart();                                    // Restart ESP32
  }

  MDNS.begin("breadmonitor");                         // Start mDNS

  pinMode(trigPin, OUTPUT);                           // Set trigger pin as output
  pinMode(echoPin, INPUT);                            // Set echo pin as input
  dht.begin();                                        // Start DHT sensor

  server.on("/", handleRoot);                         // Root page route
  server.on("/data", handleData);                     // Data route
  server.on("/action", handleAction);                 // Action route
  server.onNotFound(handleNotFound);                  // 404 handler

  server.on("/status", HTTP_GET, handleStatus);       // Email status route
  server.on("/notify", HTTP_POST, handleNotify);      // Test email route
  server.on("/setRecipient", HTTP_GET, handleSetRecipient);  // Save recipient route

  server.begin();                                     // Start server
}

// Main loop
void loop() {
  server.handleClient();                              // Handle web requests
  updateExperiment();                                 // Update experiment logic

  if (sendRequested) {                                // If email requested
    sendRequested = false;                            // Clear request

    String subject = "BreadMonitor: Sourdough Doubled";  // Email subject
    String body =
      "Sourdough has approximately doubled in Volume.\n\n"  // Message line 1
      "Current total height (cm): " + String(totalHeight) + "\n"  // Height
      "Initial Height (cm): " + String(H_d) + "\n"                // Initial height
      "Constant: " + String(volumeConstant, 4) + "\n";            // Constant

    sendEmailNow(subject, body);                      // Send email
  }
}
