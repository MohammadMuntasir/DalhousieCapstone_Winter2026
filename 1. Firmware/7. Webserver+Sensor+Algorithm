// Read ultrasonic distance
float readDistanceCm(int samples) {
  float sum = 0;                               // Sum of durations
  int validsamples = 0;                        // Count valid samples
  float distance;                              // Final distance

  for (int i = 0; i < samples; i++) {         // Take multiple samples
    digitalWrite(trigPin, LOW);               // Clear trigger
    delayMicroseconds(2);                     // Short delay
    digitalWrite(trigPin, HIGH);              // Trigger pulse high
    delayMicroseconds(10);                    // Pulse width
    digitalWrite(trigPin, LOW);               // Trigger pulse low

    long duration = pulseIn(echoPin, HIGH, 30000);  // Read echo time
    if (duration > 0) {                       // Check valid reading
      sum += duration;                        // Add duration
      validsamples++;                         // Increment valid count
    }
    delay(20);                                // Delay between samples
  }

  if (validsamples == 0) {                    // No valid readings
    return NAN;                               // Return invalid number
  }

  distance = (sum / validsamples) * Sound_speed / 2.0;  // Convert to cm
  return distance;                            // Return distance
}

// Update experiment
void updateExperiment() {
  if (!experimentRunning) return;                     // Exit if stopped
  if (millis() - lastUpdate < UPDATE_MS) return;     // Wait for interval
  lastUpdate = millis();                              // Update timer

  currentDistance = readDistanceCm(10);              // Read current distance
  if (isnan(currentDistance) || isnan(H_o) || isnan(H_d) || isnan(volumeConstant)) return;  // Validate values

  rise = H_o - currentDistance;                      // Calculate rise
  totalHeight = rise + H_d;                          // Calculate total height

  float target = volumeConstant * H_d;              // Calculate target

  if (fabs(totalHeight - target) < 0.5) {           // Check tolerance
    if (!alarmTriggered) {                          // If alarm not yet triggered
      alarmTriggered = true;                        // Trigger alarm

      if (!alarmEmailSent) {                        // If email not yet sent
        sendRequested = true;                       // Request email send
        alarmEmailSent = true;                      // Mark email sent
        lastStatus = "Email queued...";             // Update status
      }
    }
  }
}

// Email callback
void smtpCallback(SMTP_Status status) {
  if (status.success()) lastStatus = "Email sent";  // Success message
  else lastStatus = "Email failed";                 // Failure message
}

// Send email
bool sendEmailNow(const String& subject, const String& bodyText) {
  if (recipientEmail.length() < 6 || recipientEmail.indexOf('@') < 1 || recipientEmail.indexOf('.') < 3) {  // Validate email
    lastStatus = "Set a valid recipient email first";  // Invalid email status
    return false;                                      // Stop sending
  }

  session.server.host_name = SMTP_HOST;         // Set SMTP host
  session.server.port = SMTP_PORT;              // Set SMTP port
  session.login.email = AUTHOR_EMAIL;           // Set sender email
  session.login.password = AUTHOR_APP_PASS;     // Set app password
  session.login.user_domain = "";               // Empty domain

  message.clear();                              // Clear old message
  message.sender.name = "Bread Rising Monitor"; // Sender name
  message.sender.email = AUTHOR_EMAIL;          // Sender email
  message.subject = subject;                    // Email subject
  message.addRecipient("User", recipientEmail.c_str());  // Add recipient

  message.text.content = bodyText.c_str();      // Email body
  message.text.charSet = "utf-8";               // Character set
  message.text.transfer_encoding = Content_Transfer_Encoding::enc_7bit;  // Encoding

  smtp.callback(smtpCallback);                  // Attach callback

  if (!smtp.connect(&session)) {                // Connect to SMTP
    lastStatus = "SMTP connect failed";         // Connection failed status
    smtp.closeSession();                        // Close session
    return false;                               // Return failure
  }

  bool ok = MailClient.sendMail(&smtp, &message);  // Send email
  smtp.closeSession();                             // Close session

  lastStatus = ok ? "Email sent" : "Send failed";  // Update status
  return ok;                                       // Return result
}

// /data endpoint
void handleData() {
  float h = dht.readHumidity();                  // Read humidity
  float t = dht.readTemperature();               // Read temperature

  if (isnan(h) || isnan(t)) {                    // Check sensor failure
    server.send(500, "application/json", R"({"error":"Sensor failure"})");  // Send error
    return;                                      // Exit
  }

  String json = "{";                             // Start JSON
  json += "\"temperature\":" + String(t) + ","; // Add temperature
  json += "\"humidity\":" + String(h) + ",";    // Add humidity
  json += "\"running\":" + String(experimentRunning ? "true" : "false") + ",";  // Add running state
  json += "\"alarm\":" + String(alarmTriggered ? "true" : "false") + ",";        // Add alarm state
  json += "\"metricName\":\"Total Height (cm)\",";  // Add metric name

  if (!isnan(totalHeight)) json += "\"metric\":" + String(totalHeight) + ",";  // Add height
  else json += "\"metric\":null,";                                            // Add null

  if (!isnan(H_sensor)) json += "\"H_sensor\":" + String(H_sensor) + ",";     // Add H_sensor
  else json += "\"H_sensor\":null,";                                           // Add null

  if (!isnan(H_o)) json += "\"H_o\":" + String(H_o) + ",";                    // Add H_o
  else json += "\"H_o\":null,";                                                // Add null

  if (!isnan(H_d)) json += "\"H_d\":" + String(H_d) + ",";                    // Add H_d
  else json += "\"H_d\":null,";                                                // Add null

  if (!isnan(H_sensor_const)) json += "\"H_sensor_const\":" + String(H_sensor_const) + ",";  // Add constant base
  else json += "\"H_sensor_const\":null,";                                                    // Add null

  if (!isnan(H_500)) json += "\"H_500\":" + String(H_500) + ",";              // Add H_500
  else json += "\"H_500\":null,";                                              // Add null

  if (!isnan(H_1000)) json += "\"H_1000\":" + String(H_1000) + ",";           // Add H_1000
  else json += "\"H_1000\":null,";                                             // Add null

  if (!isnan(volumeConstant)) json += "\"constant\":" + String(volumeConstant, 4) + ",";  // Add constant
  else json += "\"constant\":null,";                                                         // Add null

  json += "\"timeReady\":" + String(timeReady ? "true" : "false");            // Add time status
  json += "}";                                                                 // End JSON

  server.send(200, "application/json", json);                                  // Send JSON
}

// /action endpoint
void handleAction() {
  if (!server.hasArg("cmd")) {                        // Check command exists
    server.send(400, "text/plain", "Missing cmd");   // Send error
    return;                                          // Exit
  }

  String cmd = server.arg("cmd");                    // Read command

  if (cmd == "constBase") {                          // Constant base command
    H_sensor_const = readDistanceCm(100);            // Read base distance
    H_500 = NAN;                                     // Reset H_500
    H_1000 = NAN;                                    // Reset H_1000
    volumeConstant = NAN;                            // Reset constant
    server.send(200, "text/plain", isnan(H_sensor_const) ? "FAIL" : "OK");  // Send status
    return;                                          // Exit
  }

  if (cmd == "cal500") {                             // 500 mL command
    if (isnan(H_sensor_const)) {                     // Check base first
      server.send(400, "text/plain", "Read constant base first");  // Error
      return;                                        // Exit
    }
    H_500 = readDistanceCm(100);                     // Read 500 mL
    server.send(200, "text/plain", isnan(H_500) ? "FAIL" : "OK");  // Send status
    return;                                          // Exit
  }

  if (cmd == "cal1000") {                            // 1000 mL command
    if (isnan(H_sensor_const) || isnan(H_500)) {    // Check previous steps
      server.send(400, "text/plain", "Do constant base + 500 mL first");  // Error
      return;                                        // Exit
    }
    H_1000 = readDistanceCm(100);                    // Read 1000 mL

    if (!isnan(H_1000)) {                            // If valid reading
      float height_500 = H_sensor_const - H_500;    // Height for 500 mL
      float height_1000 = H_sensor_const - H_1000;  // Height for 1000 mL
      if (height_500 != 0) {                         // Prevent divide by zero
        volumeConstant = height_1000 / height_500;  // Calculate constant
      }
    }

    server.send(200, "text/plain", (isnan(H_1000) || isnan(volumeConstant)) ? "FAIL" : "OK");  // Send status
    return;                                          // Exit
  }

  if (cmd == "setConstant") {                        // Manual constant command
    if (!server.hasArg("value")) {                   // Check value exists
      server.send(400, "text/plain", "Missing value");  // Error
      return;                                        // Exit
    }

    float val = server.arg("value").toFloat();       // Convert value
    if (val <= 0) {                                  // Check valid value
      server.send(400, "text/plain", "Invalid constant");  // Error
      return;                                        // Exit
    }

    volumeConstant = val;                            // Save constant
    server.send(200, "text/plain", "OK");            // Send success
    return;                                          // Exit
  }

  if (cmd == "base") {                               // Experiment base command
    H_sensor = readDistanceCm(100);                  // Read base
    H_o = NAN;                                       // Reset H_o
    H_d = NAN;                                       // Reset H_d
    rise = NAN;                                      // Reset rise
    totalHeight = NAN;                               // Reset total height
    experimentRunning = false;                       // Stop experiment
    alarmTriggered = false;                          // Reset alarm
    alarmEmailSent = false;                          // Reset email flag

    server.send(200, "text/plain", isnan(H_sensor) ? "FAIL" : "OK");  // Send status
    return;                                          // Exit
  }

  if (cmd == "surface") {                            // Surface command
    if (isnan(H_sensor)) {                           // Require base first
      server.send(400, "text/plain", "Read experiment base first");  // Error
      return;                                        // Exit
    }

    H_o = readDistanceCm(100);                       // Read initial surface
    if (!isnan(H_o)) {                               // If valid reading
      H_d = H_sensor - H_o;                          // Calculate initial height
      rise = 0;                                      // Initial rise is zero
      totalHeight = H_d;                             // Set total height
    }

    experimentRunning = false;                       // Stop experiment
    alarmTriggered = false;                          // Reset alarm
    alarmEmailSent = false;                          // Reset email flag

    server.send(200, "text/plain", isnan(H_o) ? "FAIL" : "OK");  // Send status
    return;                                          // Exit
  }

  if (cmd == "start") {                              // Start command
    if (isnan(H_sensor) || isnan(H_o) || isnan(H_d) || isnan(volumeConstant)) {  // Check setup complete
      server.send(400, "text/plain", "Do experiment base + surface + constant first");  // Error
      return;                                        // Exit
    }

    alarmTriggered = false;                          // Reset alarm
    alarmEmailSent = false;                          // Reset email flag
    experimentRunning = true;                        // Start experiment
    lastUpdate = 0;                                  // Reset timer
    server.send(200, "text/plain", "OK");            // Send success
    return;                                          // Exit
  }

  if (cmd == "stop") {                               // Stop command
    experimentRunning = false;                       // Stop experiment
    server.send(200, "text/plain", "OK");            // Send success
    return;                                          // Exit
  }

  if (cmd == "resetAlarm") {                         // Reset alarm command
    alarmTriggered = false;                          // Reset alarm
    alarmEmailSent = false;                          // Reset email flag
    server.send(200, "text/plain", "OK");            // Send success
    return;                                          // Exit
  }

  server.send(400, "text/plain", "Unknown cmd");     // Unknown command
}

// /status endpoint
void handleStatus() {
  String json = "{";                                 // Start JSON
  json += "\"status\":\"" + lastStatus + "\",";      // Add email status
  json += "\"recipient\":\"" + recipientEmail + "\"";  // Add recipient
  json += "}";                                       // End JSON
  server.send(200, "application/json", json);        // Send response
}

// /notify endpoint
void handleNotify() {
  sendRequested = true;                              // Request email send
  server.send(200, "application/json", "{\"ok\":true}");  // Send response
}

// /setRecipient endpoint
void handleSetRecipient() {
  if (!server.hasArg("email")) {                     // Check email argument
    server.send(400, "text/plain", "Missing email"); // Send error
    return;                                          // Exit
  }

  String e = server.arg("email");                    // Read email
  e.trim();                                          // Remove spaces

  if (e.length() < 6 || e.indexOf('@') < 1 || e.indexOf('.') < 3) {  // Validate email
    server.send(400, "text/plain", "Invalid email"); // Send error
    return;                                          // Exit
  }

  recipientEmail = e;                                // Save recipient
  lastStatus = "Recipient set";                      // Update status
  server.send(200, "text/plain", "OK");              // Send success
}

