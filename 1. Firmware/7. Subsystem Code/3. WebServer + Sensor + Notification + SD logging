/*===Time / NTP helpers===*/
String getFormattedDateTime() {               // Get formatted date/time
  struct tm timeinfo;                         // Time structure
  if (!getLocalTime(&timeinfo)) {            // Check if time is available
    return "0000-00-00 00:00:00";            // Return default time if failed
  }
  char buf[25];                               // Character buffer
  strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", &timeinfo); // Format time
  return String(buf);                         // Return as String
}

unsigned long getTimeStamp() {               // Get Unix timestamp
  time_t now;                                // Current time variable
  struct tm timeinfo;                        // Time structure

  if (!getLocalTime(&timeinfo)) {            // Check if time exists
    return 0;                                // Return 0 if failed
  }

  time(&now);                                // Read current time
  return (unsigned long)now;                 // Return timestamp
}

/*===Ultrasonic readDistanceCm===*/
float readDistanceCm(int samples) {          // Read averaged distance
  float sum = 0;                             // Sum of durations
  int validsamples = 0;                      // Count valid readings
  float distance;                            // Final distance

  for (int i = 0; i < samples; i++) {       // Take multiple samples
    digitalWrite(trigPin, LOW);             // Clear trigger
    delayMicroseconds(2);                   // Small delay
    digitalWrite(trigPin, HIGH);            // Send trigger pulse
    delayMicroseconds(10);                  // Hold pulse
    digitalWrite(trigPin, LOW);             // End trigger pulse

    long duration = pulseIn(echoPin, HIGH, 30000); // Read echo time
    if (duration > 0) {                     // Check valid duration
      sum += duration;                      // Add duration to sum
      validsamples++;                       // Increase valid count
    }
    delay(20);                              // Small delay between samples
  }

  if (validsamples == 0) {                  // If no valid readings
    return NAN;                             // Return invalid number
  }

  distance = (sum / validsamples) * Sound_speed / 2.0; // Convert to cm
  return distance;                          // Return distance
}

/*===Experiment update===*/
void updateExperiment() {                    // Update experiment values
  if (!experimentRunning) return;            // Stop if experiment not running
  if (millis() - lastUpdate < UPDATE_MS) return; // Wait for next update time
  lastUpdate = millis();                     // Save update time

  currentDistance = readDistanceCm(10);      // Read current distance
  if (isnan(currentDistance) || isnan(H_o) || isnan(H_d) || isnan(volumeConstant)) return; // Exit if invalid

  rise = H_o - currentDistance;              // Calculate rise
  totalHeight = rise + H_d;                  // Calculate total height

  float target = volumeConstant * H_d;       // Calculate target height

  if (fabs(totalHeight - target) < 0.5) {    // Check if target reached
    if (!alarmTriggered) {                   // Only trigger once
      alarmTriggered = true;                 // Set alarm flag

      if (!alarmEmailSent) {                 // If email not sent yet
        sendRequested = true;                // Request email send
        alarmEmailSent = true;               // Mark email sent
        lastStatus = "Email queued...";      // Update email status
      }
    }
  }
}

/*===SD card functions===*/
void appendFile(fs::FS& fs, const char* path, const char* message) { // Append text to file
  File file = fs.open(path, FILE_APPEND);    // Open file in append mode
  if (!file) return;                         // Exit if file failed
  file.print(message);                       // Write message to file
  file.close();                              // Close file
}

void ensureLogHeader() {                     // Make sure CSV header exists
  if (!sdReady) return;                      // Exit if SD not ready
  if (!SD.exists(LOG_PATH)) {                // Check if log file exists
    File file = SD.open(LOG_PATH, FILE_WRITE); // Create file
    if (file) {                              // If file opened
      file.println("Timestamp,TemperatureC,HumidityPct,TotalHeightCm,InitialHeightCm"); // Write header
      file.close();                          // Close file
    }
  }
}

void logBreadData(float temperature, float humidity) { // Log data to CSV
  if (!sdReady) return;                      // Exit if SD not ready
  if (isnan(temperature) || isnan(humidity)) return; // Exit if sensor invalid

  String ts = getFormattedDateTime();        // Get timestamp

  String line = ts + "," +                   // Start CSV line
                String(temperature, 1) + "," +
                String(humidity, 1) + ",";

  if (!isnan(totalHeight)) line += String(totalHeight, 2); // Add total height
  else                     line += "";                     // Leave blank if invalid

  line += ",";                              // Add next comma

  if (!isnan(H_d)) line += String(H_d, 2); // Add initial height
  else             line += "";             // Leave blank if invalid

  line += "\n";                            // End line
  appendFile(SD, LOG_PATH, line.c_str());  // Save line to file
}

/*===CSV download + clear===*/
void handleDownloadCSV() {                   // Download CSV file
  if (!sdReady) {                           // Check SD card
    server.send(500, "text/plain", "SD not ready"); // Send error
    return;                                 // Exit function
  }
  if (!SD.exists(LOG_PATH)) {               // Check file exists
    server.send(404, "text/plain", "Log file not found"); // Send error
    return;                                 // Exit function
  }

  File file = SD.open(LOG_PATH, FILE_READ); // Open log file
  if (!file) {                              // Check file opened
    server.send(500, "text/plain", "Failed to open log"); // Send error
    return;                                 // Exit function
  }

  server.sendHeader("Content-Type", "text/csv"); // Set CSV content type
  server.sendHeader("Content-Disposition", "attachment; filename=\"fermentation_log.csv\""); // Set file name
  server.sendHeader("Connection", "close"); // Close connection after send
  server.streamFile(file, "text/csv");      // Send file to browser
  file.close();                             // Close file
}

void handleClearCSV() {                      // Clear CSV file
  if (!sdReady) {                           // Check SD card
    server.send(500, "text/plain", "SD not ready"); // Send error
    return;                                 // Exit function
  }
  if (SD.exists(LOG_PATH)) SD.remove(LOG_PATH); // Delete old log file
  ensureLogHeader();                        // Recreate header
  server.send(200, "text/plain", "OK");     // Send success message
}

/*===Email functions===*/
void smtpCallback(SMTP_Status status) {      // SMTP callback function
  if (status.success()) lastStatus = "Email sent"; // Success status
  else                  lastStatus = "Email failed"; // Failure status
}

bool sendEmailNow(const String& subject, const String& bodyText) { // Send email now
  if (recipientEmail.length() < 6 || recipientEmail.indexOf('@') < 1 || recipientEmail.indexOf('.') < 3) { // Validate email
    lastStatus = "Set a valid recipient email first"; // Update status
    return false;                           // Stop function
  }

  session.server.host_name = SMTP_HOST;     // Set SMTP host
  session.server.port = SMTP_PORT;          // Set SMTP port
  session.login.email = AUTHOR_EMAIL;       // Set sender email
  session.login.password = AUTHOR_APP_PASS; // Set app password
  session.login.user_domain = "";           // Set domain empty

  message.clear();                          // Clear old message
  message.sender.name = "Bread Rising Monitor"; // Sender name
  message.sender.email = AUTHOR_EMAIL;      // Sender email
  message.subject = subject;                // Email subject
  message.addRecipient("User", recipientEmail.c_str()); // Add recipient

  message.text.content = bodyText.c_str();  // Set email body
  message.text.charSet = "utf-8";           // Set charset
  message.text.transfer_encoding = Content_Transfer_Encoding::enc_7bit; // Set encoding

  smtp.callback(smtpCallback);              // Set callback function

  if (!smtp.connect(&session)) {            // Connect to SMTP
    lastStatus = "SMTP connect failed";     // Update error
    smtp.closeSession();                    // Close session
    return false;                           // Stop function
  }

  bool ok = MailClient.sendMail(&smtp, &message); // Send email
  smtp.closeSession();                      // Close SMTP session

  lastStatus = ok ? "Email sent" : "Send failed"; // Final status
  return ok;                                // Return result
}

