/*===Setup / Loop===*/
void setup() {                               // Setup function
  WiFiManager wm;                            // Create WiFiManager object
  bool connect = wm.autoConnect("BreadMonitorSetup"); // Start WiFi portal
  if (!connect) {                            // If WiFi fails
    ESP.restart();                           // Restart ESP32
  }

  MDNS.begin("breadmonitor");                // Start mDNS service

  pinMode(trigPin, OUTPUT);                  // Set trig pin output
  pinMode(echoPin, INPUT);                   // Set echo pin input
  dht.begin();                               // Start DHT sensor

  sdReady = SD.begin();                      // Start SD card
  if (sdReady) {                             // If SD works
    ensureLogHeader();                       // Make sure CSV header exists
  }

  if (WiFi.status() == WL_CONNECTED) {       // If WiFi connected
    configTime(gmtOffset_sec, daylightOffset_sec, ntpServer); // Start NTP time
    struct tm timeinfo;                      // Time structure
    timeReady = getLocalTime(&timeinfo);     // Check time available
  }

  server.on("/", handleRoot);                // Root route
  server.on("/data", handleData);            // Data route
  server.on("/action", handleAction);        // Action route
  server.onNotFound(handleNotFound);         // 404 route

  server.on("/status", HTTP_GET, handleStatus);      // Email status route
  server.on("/notify", HTTP_POST, handleNotify);     // Test email route
  server.on("/setRecipient", HTTP_GET, handleSetRecipient); // Set recipient route

  server.on("/download", HTTP_GET, handleDownloadCSV); // Download CSV route
  server.on("/clearlog", HTTP_POST, handleClearCSV);  // Clear CSV route

  server.begin();                            // Start web server

  lastLog = millis();                        // Initialize log timer
}

void loop() {                                // Main loop
  server.handleClient();                     // Handle web requests
  updateExperiment();                        // Update experiment logic

  unsigned long now = millis();              // Read current time

  if (now - lastLog >= LOG_INTERVAL_MS) {    // Check logging interval
    float h = dht.readHumidity();            // Read humidity
    float t = dht.readTemperature();         // Read temperature
    logBreadData(t, h);                      // Save data to CSV
    lastLog = now;                           // Reset log timer
  }

  if (sendRequested) {                       // Check email request
    sendRequested = false;                   // Clear request flag

    String subject = "BreadMonitor: Sourdough Doubled"; // Email subject
    String body =
      "Sourdough has approximately doubled in Volume.\n\n"
      "Current total height (cm): " + String(totalHeight) + "\n"
      "Initial Height (cm): " + String(H_d) + "\n"
      "Constant: " + String(volumeConstant, 4) + "\n"; // Email body

    sendEmailNow(subject, body);             // Send email
  }
}
