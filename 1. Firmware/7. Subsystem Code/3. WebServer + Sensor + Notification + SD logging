/*===/action endpoint===*/
void handleAction() {                         // Handle button actions
  if (!server.hasArg("cmd")) {               // Check cmd argument
    server.send(400, "text/plain", "Missing cmd"); // Send error
    return;                                  // Exit function
  }

  String cmd = server.arg("cmd");            // Read command

  if (cmd == "constBase") {                  // Constant base command
    H_sensor_const = readDistanceCm(100);    // Read empty container distance
    H_500 = NAN;                             // Reset 500mL value
    H_1000 = NAN;                            // Reset 1000mL value
    volumeConstant = NAN;                    // Reset constant
    server.send(200, "text/plain", isnan(H_sensor_const) ? "FAIL" : "OK"); // Send response
    return;                                  // Exit command
  }

  if (cmd == "cal500") {                     // 500mL command
    if (isnan(H_sensor_const)) {             // Check base first
      server.send(400, "text/plain", "Read constant base first"); // Send error
      return;                                // Exit command
    }
    H_500 = readDistanceCm(100);             // Read 500mL distance
    server.send(200, "text/plain", isnan(H_500) ? "FAIL" : "OK"); // Send response
    return;                                  // Exit command
  }

  if (cmd == "cal1000") {                    // 1000mL command
    if (isnan(H_sensor_const) || isnan(H_500)) { // Check previous steps
      server.send(400, "text/plain", "Do constant base + 500 mL first"); // Send error
      return;                                // Exit command
    }
    H_1000 = readDistanceCm(100);            // Read 1000mL distance

    if (!isnan(H_1000)) {                    // If valid reading
      float height_500 = H_sensor_const - H_500;     // Calculate 500mL height
      float height_1000 = H_sensor_const - H_1000;   // Calculate 1000mL height
      if (height_500 != 0) {                 // Avoid divide by zero
        volumeConstant = height_1000 / height_500; // Compute constant
      }
    }

    server.send(200, "text/plain", (isnan(H_1000) || isnan(volumeConstant)) ? "FAIL" : "OK"); // Send response
    return;                                  // Exit command
  }

  if (cmd == "setConstant") {                // Manual constant command
    if (!server.hasArg("value")) {           // Check value exists
      server.send(400, "text/plain", "Missing value"); // Send error
      return;                                // Exit command
    }

    float val = server.arg("value").toFloat(); // Convert value to float
    if (val <= 0) {                          // Check valid number
      server.send(400, "text/plain", "Invalid constant"); // Send error
      return;                                // Exit command
    }

    volumeConstant = val;                    // Save manual constant
    server.send(200, "text/plain", "OK");    // Send success
    return;                                  // Exit command
  }

  if (cmd == "base") {                       // Experiment base command
    H_sensor = readDistanceCm(100);          // Read empty container distance
    H_o = NAN;                               // Reset H_o
    H_d = NAN;                               // Reset H_d
    rise = NAN;                              // Reset rise
    totalHeight = NAN;                       // Reset total height
    experimentRunning = false;               // Stop experiment
    alarmTriggered = false;                  // Reset alarm
    alarmEmailSent = false;                  // Reset email flag

    server.send(200, "text/plain", isnan(H_sensor) ? "FAIL" : "OK"); // Send response
    return;                                  // Exit command
  }

  if (cmd == "surface") {                    // Experiment surface command
    if (isnan(H_sensor)) {                   // Check base first
      server.send(400, "text/plain", "Read experiment base first"); // Send error
      return;                                // Exit command
    }

    H_o = readDistanceCm(100);               // Read dough surface distance
    if (!isnan(H_o)) {                       // If valid reading
      H_d = H_sensor - H_o;                  // Calculate initial height
      rise = 0;                              // Initial rise is zero
      totalHeight = H_d;                     // Set total height
    }

    experimentRunning = false;               // Keep experiment stopped
    alarmTriggered = false;                  // Reset alarm
    alarmEmailSent = false;                  // Reset email flag

    server.send(200, "text/plain", isnan(H_o) ? "FAIL" : "OK"); // Send response
    return;                                  // Exit command
  }

  if (cmd == "start") {                      // Start command
    if (isnan(H_sensor) || isnan(H_o) || isnan(H_d) || isnan(volumeConstant)) { // Check setup complete
      server.send(400, "text/plain", "Do experiment base + surface + constant first"); // Send error
      return;                                // Exit command
    }

    alarmTriggered = false;                  // Reset alarm
    alarmEmailSent = false;                  // Reset email sent flag
    experimentRunning = true;                // Start experiment
    lastUpdate = 0;                          // Reset timer
    server.send(200, "text/plain", "OK");    // Send success
    return;                                  // Exit command
  }

  if (cmd == "stop") {                       // Stop command
    experimentRunning = false;               // Stop experiment
    server.send(200, "text/plain", "OK");    // Send success
    return;                                  // Exit command
  }

  if (cmd == "resetAlarm") {                 // Reset alarm command
    alarmTriggered = false;                  // Reset alarm
    alarmEmailSent = false;                  // Reset email flag
    server.send(200, "text/plain", "OK");    // Send success
    return;                                  // Exit command
  }

  server.send(400, "text/plain", "Unknown cmd"); // Unknown command
}

