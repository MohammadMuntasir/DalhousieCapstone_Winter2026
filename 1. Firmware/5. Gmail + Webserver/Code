//Include required libraries
#include<WiFi.h>             //WiFi functions
#include<WebServer.h>        //Web server functions
#include<ESPmDNS.h>          //Local name access
#include<WiFiManager.h>      //WiFi setup portal
#include <ESP_Mail_Client.h> //Email sending library

//Create web server
WebServer server(80);        //Server on port 80

//Gmail SMTP settings
#define AUTHOR_EMAIL    "breadrisingmonitor@gmail.com"
#define AUTHOR_PASSWORD "kjcd lstj cxqk bfqf"

#define SMTP_HOST "smtp.gmail.com"
#define SMTP_PORT 465

SMTPSession smtp;            //SMTP session object
ESP_Mail_Session session;    //Email session settings
SMTP_Message message;        //Email message object

String recipientEmail = "";  //Stores entered email
String emailStatus = "Idle"; //Stores current email status

//SMTP callback function
void smtpCallback(SMTP_Status status) {
  if (status.success())
    emailStatus = "Email sent successfully"; //Update success status
  else
    emailStatus = "Email failed"; //Update fail status
}

//Send email function
bool sendEmailNow() {
  if (recipientEmail.length() < 6) {
    emailStatus = "Invalid email"; //Check basic email length
    return false;
  }

  session.server.host_name = SMTP_HOST;      //Set SMTP host
  session.server.port = SMTP_PORT;           //Set SMTP port
  session.login.email = AUTHOR_EMAIL;        //Set sender email
  session.login.password = AUTHOR_PASSWORD;  //Set sender password
  session.login.user_domain = "";            //No domain needed

  message.clear();                           //Clear previous message
  message.sender.name = "ESP32 Webserver";   //Set sender name
  message.sender.email = AUTHOR_EMAIL;       //Set sender email
  message.subject = "ESP32 Notification";    //Set email subject
  message.addRecipient("User", recipientEmail.c_str()); //Add receiver

  message.text.content = "Email sent using ESP32 webserver"; //Email body
  message.text.charSet = "utf-8";            //Set text encoding

  smtp.callback(smtpCallback);               //Attach callback function

  if (!smtp.connect(&session)) {
    emailStatus = "SMTP connection failed";  //Fail if server not connected
    return false;
  }

  bool success = MailClient.sendMail(&smtp, &message); //Send email
  smtp.closeSession();                                  //Close SMTP session

  emailStatus = success ? "Email sent successfully" : "Send failed"; //Final status
  return success;
}

//Root web page
void handleRoot() {
  String html = R"rawliteral(
  <!DOCTYPE html>
  <html>
  <head>
    <title>ESP32 Email Sender</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      body { font-family: Arial; padding: 20px; }
      input, button { padding: 10px; margin: 10px 0; width: 100%; }
    </style>
  </head>
  <body>
    <h2>ESP32 Email Sender</h2>
    <input type="email" id="email" placeholder="Enter your email">
    <button onclick="sendEmail()">Send Email</button>
    <p id="status">Status: ---</p>

    <script>
      async function sendEmail() {
        let email = document.getElementById("email").value;
        let response = await fetch(`/send?email=${encodeURIComponent(email)}`);
        let text = await response.text();
        document.getElementById("status").innerHTML = "Status: " + text;
      }
    </script>
  </body>
  </html>
  )rawliteral";

  server.send(200, "text/html", html); //Send webpage to browser
}

//Handle send route
void handleSend() {
  if (!server.hasArg("email")) {
    server.send(400, "text/plain", "No email provided"); //Check email argument
    return;
  }

  recipientEmail = server.arg("email"); //Get entered email
  recipientEmail.trim();                //Remove extra spaces

  bool result = sendEmailNow();         //Try sending email

  if (result)
    server.send(200, "text/plain", "Email sent successfully"); //Success reply
  else
    server.send(500, "text/plain", emailStatus); //Fail reply
}

//Setup function
void setup() {
  Serial.begin(115200);                 //Start serial monitor

  WiFiManager wm;                       //Create WiFiManager object
  wm.autoConnect("ESP32_Email_Setup");  //Start auto WiFi portal

  MDNS.begin("breadmonitor");           //Start mDNS service

  server.on("/", handleRoot);           //Root page route
  server.on("/send", handleSend);       //Send email route

  server.begin();                       //Start web server
}

//Main loop
void loop() {
  server.handleClient();                //Handle incoming client requests
}
