// Library Setup
#include<WiFi.h>          // Enables WiFi functionality for ESP32
#include<WebServer.h>     // Allows ESP32 to host a local web server
#include<ESPmDNS.h>       // Enables local domain access using .local hostname
#include<WiFiManager.h>   // Allows WiFi setup without hardcoded SSID and password

// Connecting to server
WebServer server(80);     // Creates web server object on port 80 (HTTP)

void setup() {
  WiFiManager wm;                                       // Setting up Wifi Manager to connect without SSID and password
  bool connect = wm.autoConnect("Esp32MonitorSetup");   // Creates AP portal if WiFi credentials are not saved

  if(!connect){
    ESP.restart();       // Restart ESP32 if WiFi connection fails
  }

  // Setup Domain name
  MDNS.begin("Esp32monitor");  // Enables access through esp32monitor.local
  
  // Setup server
  server.on("/",handle_OnConnect);  // Loads homepage when root URL is accessed

  server.onNotFound(handleNotFound);  // Handles invalid page requests

  server.begin();  // Starts the web server
}

void loop() {
  server.handleClient();  // Continuously listens for client requests
}

void handle_OnConnect(){
  String html = generateHTML();  // Calls HTML generation function
  
  server.send(200,"text/html",html);  // Sends webpage to client browser
}

//Refer to HTML section for the comments
String generateHTML(){
  String html = R"rawliteral(
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Webserver</title>
    </head>
    <body>
        <h1>Hello From ESP32 server</h1>
        <p>This test uses ESP32 server to display the text using ESP32 
        setup domain name and without hardcoding SSID and password</p>
    </body>
    </html>
  )rawliteral";
  return html;   // Returns HTML content as string
}

void handleNotFound(){
  server.send(404,"text/plain","Page Not found");   // Sends error message for invalid URL requests
}
