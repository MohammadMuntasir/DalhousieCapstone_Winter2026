  async function setConstantManual(){
    const val = document.getElementById('manualConstant').value.trim();
    if(!val){ alert("Enter a constant first"); return; }

    const r = await fetch(`/action?cmd=setConstant&value=${encodeURIComponent(val)}`);
    const t = await r.text();
    if(!r.ok){ alert(t); return; }
  }

  function pushLimited(labels, dataArr, x, y){
    labels.push(x);
    dataArr.push(y);
    if(labels.length > 180){
      labels.shift();
      dataArr.shift();
    }
  }

  async function updateData(){
    const res = await fetch('/data');
    if(!res.ok) return;
    const data = await res.json();

    const time = new Date().toLocaleTimeString();

    document.getElementById('temp').textContent = data.temperature;
    document.getElementById('hum').textContent = data.humidity;

    document.getElementById('running').textContent = data.running ? "RUNNING" : "STOPPED";
    document.getElementById('running').className = data.running ? "ok" : "bad";

    document.getElementById('alarm').textContent = data.alarm ? "TRIGGERED" : "OK";
    document.getElementById('alarm').className = data.alarm ? "bad" : "ok";

    document.getElementById('metricVal').textContent = (data.metric === null) ? "---" : data.metric;
    document.getElementById('metricValChart').textContent = (data.metric === null) ? "---" : data.metric;

    document.getElementById('Hs').textContent = (data.H_sensor === null) ? "---" : data.H_sensor;
    document.getElementById('Ho').textContent = (data.H_o === null) ? "---" : data.H_o;
    document.getElementById('Hd').textContent = (data.H_d === null) ? "---" : data.H_d;

    document.getElementById('HsConst').textContent = (data.H_sensor_const === null) ? "---" : data.H_sensor_const;
    document.getElementById('H500').textContent = (data.H_500 === null) ? "---" : data.H_500;
    document.getElementById('H1000').textContent = (data.H_1000 === null) ? "---" : data.H_1000;
    document.getElementById('constVal').textContent = (data.constant === null) ? "---" : data.constant;

    document.getElementById('sd').textContent = data.sdReady ? "OK" : "NO";
    document.getElementById('tm').textContent = data.timeReady ? "OK" : "NO";

    if(data.running){
      pushLimited(tLabels, tData, time, data.temperature);
      pushLimited(hLabels, hData, time, data.humidity);
      if(data.metric !== null){
        pushLimited(mLabels, mData, time, data.metric);
      }
    }

    tempChart.update();
    humChart.update();
    metricChart.update();
  }

  async function refreshEmail(){
    const r = await fetch('/status');
    if(!r.ok) return;
    const j = await r.json();
    document.getElementById('emailSt').textContent = j.status || "---";
    document.getElementById('recShow').textContent = (j.recipient && j.recipient.length) ? j.recipient : "---";
  }

  async function setRecipient(){
    const e = document.getElementById('rec').value.trim();
    if(!e){ alert("Enter an email first"); return; }
    const r = await fetch(`/setRecipient?email=${encodeURIComponent(e)}`);
    const t = await r.text();
    if(!r.ok){ alert(t); return; }
    refreshEmail();
  }

  async function sendTest(){
    document.getElementById('emailSt').textContent = "Sending...";
    await fetch('/notify', {method:'POST'});
    setTimeout(refreshEmail, 900);
  }

  function downloadCSV(){
    window.location.href = "/download";
  }

  async function clearCSV(){
    if(!confirm("Clear the CSV log on SD card?")) return;
    const r = await fetch("/clearlog", {method:"POST"});
    const t = await r.text();
    if(!r.ok) alert(t);
    else alert("Cleared");
  }

  setInterval(updateData, 1000);
  updateData();

  setInterval(refreshEmail, 2000);
  refreshEmail();
</script>
