void handleNotFound() {
  server.send(404, "text/plain", "Page not found"); // Send 404 error if page is not found
}

/*===Setup / Loop===*/
void setup() {
  WiFiManager wm; // Create WiFi manager object
  bool connect = wm.autoConnect("BreadMonitorSetup"); // Start auto WiFi connection portal
  if (!connect) { // Check if connection failed
    ESP.restart(); // Restart ESP32 if WiFi fails
  }

  MDNS.begin("breadmonitor"); // Enable local DNS name

  pinMode(trigPin, OUTPUT); // Set trigger pin as output
  pinMode(echoPin, INPUT); // Set echo pin as input
  dht.begin(); // Initialize DHT sensor

  sdReady = SD.begin(); // Initialize SD card
  if (sdReady) { // Check if SD card is working
    ensureLogHeader(); // Add CSV header if needed
  }

  if (WiFi.status() == WL_CONNECTED) { // Check WiFi connection
    configTime(gmtOffset_sec, daylightOffset_sec, ntpServer); // Configure NTP time
    struct tm timeinfo; // Create time structure
    timeReady = getLocalTime(&timeinfo); // Check if time is available
  }

  firebaseClient.setInsecure(); // Allow insecure HTTPS connection for Firebase

  server.on("/", handleRoot); // Home page route
  server.on("/data", handleData); // Data API route
  server.on("/action", handleAction); // Action command route
  server.onNotFound(handleNotFound); // Handle invalid routes

  server.on("/status", HTTP_GET, handleStatus); // Email status route
  server.on("/notify", HTTP_POST, handleNotify); // Notification request route
  server.on("/setRecipient", HTTP_GET, handleSetRecipient); // Set email route

  server.on("/download", HTTP_GET, handleDownloadCSV); // Download CSV route
  server.on("/clearlog", HTTP_POST, handleClearCSV); // Clear CSV route

  server.begin(); // Start web server

  lastLog = millis(); // Initialize logging timer
  lastFirebaseSend = millis(); // Initialize Firebase timer
}

void loop() {
  server.handleClient(); // Handle incoming web requests
  updateExperiment(); // Update experiment logic

  unsigned long now = millis(); // Get current time

  if (now - lastLog >= LOG_INTERVAL_MS) { // Check logging interval
    float h = dht.readHumidity(); // Read humidity
    float t = dht.readTemperature(); // Read temperature
    logBreadData(t, h); // Save data to SD card
    lastLog = now; // Reset log timer
  }

  if (now - lastFirebaseSend >= FIREBASE_INTERVAL_MS) { // Check Firebase interval
    float h = dht.readHumidity(); // Read humidity
    float t = dht.readTemperature(); // Read temperature
    sendToFirebase(t, h); // Upload data to Firebase
    lastFirebaseSend = now; // Reset Firebase timer
  }

  if (sendRequested) { // Check if email needs to be sent
    sendRequested = false; // Reset request flag

    String subject = "BreadMonitor: Sourdough Doubled"; // Email subject
    String body =
      "Sourdough has approximately doubled in Volume.\n\n" // Message line 1
      "Current total height (cm): " + String(totalHeight) + "\n" // Current height
      "Initial Height (cm): " + String(H_d) + "\n" // Initial height
      "Constant: " + String(volumeConstant, 4) + "\n"; // Calibration constant

    sendEmailNow(subject, body); // Send notification email
  }
}


