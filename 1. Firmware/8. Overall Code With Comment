/*===SD card functions===*/
void appendFile(fs::FS& fs, const char* path, const char* message) { // Function to append text to file
  File file = fs.open(path, FILE_APPEND);       // Open file in append mode
  if (!file) return;                            // Exit if file failed to open
  file.print(message);                          // Write message to file
  file.close();                                 // Close file after writing
}

void ensureLogHeader() {                        // Function to create CSV header if file does not exist
  if (!sdReady) return;                         // Exit if SD card is not ready
  if (!SD.exists(LOG_PATH)) {                   // Check if log file does not exist
    File file = SD.open(LOG_PATH, FILE_WRITE);  // Open log file in write mode
    if (file) {                                 // Check if file opened successfully
      file.println("Timestamp,TemperatureC,HumidityPct,TotalHeightCm,InitialHeightCm"); // Write CSV header
      file.close();                             // Close file after writing header
    }
  }
}

void logBreadData(float temperature, float humidity) { // Function to log sensor and height data to SD card
  if (!sdReady) return;                         // Exit if SD card is not ready
  if (isnan(temperature) || isnan(humidity)) return; // Exit if temperature or humidity is invalid

  String ts = getFormattedDateTime();           // Get formatted timestamp string

  String line = ts + "," +                      // Start CSV line with timestamp
                String(temperature, 1) + "," +  // Add temperature with 1 decimal place
                String(humidity, 1) + ",";      // Add humidity with 1 decimal place

  if (!isnan(totalHeight)) line += String(totalHeight, 2); // Add total height if valid
  else                     line += "";                    // Leave field blank if invalid

  line += ",";                                // Add comma separator

  if (!isnan(H_d)) line += String(H_d, 2);     // Add initial height if valid
  else             line += "";                 // Leave field blank if invalid

  line += "\n";                               // Add newline to end of CSV row
  appendFile(SD, LOG_PATH, line.c_str());      // Append CSV row to log file
}

/*===CSV download + clear===*/
void handleDownloadCSV() {                       // Function to download CSV file through browser
  if (!sdReady) {                               // Check if SD card is not ready
    server.send(500, "text/plain", "SD not ready"); // Send server error message
    return;                                     // Exit function
  }
  if (!SD.exists(LOG_PATH)) {                   // Check if CSV file does not exist
    server.send(404, "text/plain", "Log file not found"); // Send file not found message
    return;                                     // Exit function
  }

  File file = SD.open(LOG_PATH, FILE_READ);     // Open CSV file for reading
  if (!file) {                                  // Check if file failed to open
    server.send(500, "text/plain", "Failed to open log"); // Send open failure message
    return;                                     // Exit function
  }

  server.sendHeader("Content-Type", "text/csv"); // Set response type as CSV
  server.sendHeader("Content-Disposition", "attachment; filename=\"fermentation_log.csv\""); // Force browser download with filename
  server.sendHeader("Connection", "close");   // Tell browser to close connection after response
  server.streamFile(file, "text/csv");         // Stream file contents to browser
  file.close();                                 // Close file after streaming
}

void handleClearCSV() {                         // Function to clear CSV log file
  if (!sdReady) {                               // Check if SD card is not ready
    server.send(500, "text/plain", "SD not ready"); // Send server error message
    return;                                     // Exit function
  }
  if (SD.exists(LOG_PATH)) SD.remove(LOG_PATH); // Delete log file if it exists
  ensureLogHeader();                            // Recreate CSV header after deletion
  server.send(200, "text/plain", "OK");       // Send success response
}

/*===Time / NTP helpers===*/
String getFormattedDateTime() {                  // Function to return formatted current date and time
  struct tm timeinfo;                            // Create time structure variable
  if (!getLocalTime(&timeinfo)) {                // Check if local time was retrieved successfully
    return "0000-00-00 00:00:00";                // Return default text if time is not available
  }
  char buf[25];                                  // Create character buffer for formatted time string
  strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", &timeinfo); // Format time into YYYY-MM-DD HH:MM:SS
  return String(buf);                            // Return formatted time as String
}

unsigned long getTimeStamp() {                   // Function to return Unix timestamp
  time_t now;                                    // Variable to store current time
  struct tm timeinfo;                            // Time structure variable

  if (!getLocalTime(&timeinfo)) {                // Check if local time is available
    return 0;                                    // Return 0 if time is not available
  }

  time(&now);                                    // Get current Unix time
  return (unsigned long)now;                     // Return Unix timestamp as unsigned long
}

