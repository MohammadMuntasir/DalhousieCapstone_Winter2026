/*===Firebase sender=== */
void sendToFirebase(float temperature, float humidity) { // Function to send data to Firebase
  if (WiFi.status() != WL_CONNECTED) return;   // Exit if WiFi is not connected
  if (isnan(temperature) || isnan(humidity)) return; // Exit if temperature or humidity is invalid

  unsigned long timestamp = getTimeStamp();    // Get current Unix timestamp
  if (timestamp == 0) return;                  // Exit if timestamp is invalid

  String json = "{";                           // Start JSON string
  json += "\"temperature\":" + String(temperature, 1) + ","; // Add temperature field
  json += "\"humidity\":" + String(humidity, 1) + ",";       // Add humidity field
  json += "\"timestamp\":" + String(timestamp) + ",";        // Add timestamp field

  if (!isnan(totalHeight)) json += "\"totalHeight\":" + String(totalHeight, 2) + ","; // Add totalHeight if valid
  else                     json += "\"totalHeight\":null,";                               // Add null if invalid

  if (!isnan(H_d)) json += "\"initialHeight\":" + String(H_d, 2) + ","; // Add initialHeight if valid
  else             json += "\"initialHeight\":null,";                    // Add null if invalid

  if (!isnan(H_sensor)) json += "\"H_sensor\":" + String(H_sensor, 2) + ","; // Add H_sensor if valid
  else                  json += "\"H_sensor\":null,";                         // Add null if invalid

  if (!isnan(H_o)) json += "\"H_o\":" + String(H_o, 2) + ","; // Add H_o if valid
  else             json += "\"H_o\":null,";                  // Add null if invalid

  if (!isnan(H_d)) json += "\"H_d\":" + String(H_d, 2) + ","; // Add H_d if valid
  else             json += "\"H_d\":null,";                  // Add null if invalid

  if (!isnan(volumeConstant)) json += "\"constant\":" + String(volumeConstant, 4) + ","; // Add constant if valid
  else                        json += "\"constant\":null,";                               // Add null if invalid

  json += "\"running\":";                     // Add running field name
  json += (experimentRunning ? "true" : "false"); // Add running boolean value
  json += ",";                                   // Add comma separator

  json += "\"alarm\":";                       // Add alarm field name
  json += (alarmTriggered ? "true" : "false");  // Add alarm boolean value

  json += "}";                                   // Close JSON string

  String path = String(firebaseHost) + "/breadMonitor/" + String(timestamp) + ".json"; // Create Firebase path

  HTTPClient http;                               // Create HTTP client object
  http.begin(firebaseClient, path);              // Start HTTPS connection to Firebase path
  http.addHeader("Content-Type", "application/json"); // Set request content type to JSON
  http.PUT(json);                                // Send HTTP PUT request with JSON payload
  http.end();                                    // Close HTTP connection
}

