/*===Ultrasonic readDistanceCm===*/
float readDistanceCm(int samples) {              // Function to read averaged ultrasonic distance
  float sum = 0;                                 // Variable to store sum of valid durations
  int validsamples = 0;                          // Counter for valid samples
  float distance;                                // Variable to store final calculated distance
  for (int i = 0; i < samples; i++) {            // Loop for requested number of samples
    digitalWrite(trigPin, LOW);                  // Set trigger pin low before pulse
    delayMicroseconds(2);                        // Wait 2 microseconds
    digitalWrite(trigPin, HIGH);                 // Set trigger pin high to start ultrasonic pulse
    delayMicroseconds(10);                       // Keep trigger high for 10 microseconds
    digitalWrite(trigPin, LOW);                  // Set trigger pin low to end pulse

    long duration = pulseIn(echoPin, HIGH, 30000); // Measure echo pulse duration with timeout
    if (duration > 0) {                          // Check if a valid duration was received
      sum += duration;                           // Add duration to sum
      validsamples++;                            // Increase valid sample counter
    }
    delay(20);                                   // Wait 20 ms before next sample
  }
  if (validsamples == 0) {                       // Check if no valid samples were captured
    return NAN;                                  // Return NAN if no reading is available
  }
  distance = (sum / validsamples) * Sound_speed / 2.0; // Convert average duration to distance in cm
  return distance;                               // Return calculated distance
}

/*===Experiment update===*/
void updateExperiment() {                        // Function to update experiment readings and alarm logic
  if (!experimentRunning) return;                // Exit if experiment is not running
  if (millis() - lastUpdate < UPDATE_MS) return; // Exit if update interval has not passed yet
  lastUpdate = millis();                         // Save current time as last update time

  currentDistance = readDistanceCm(10);          // Read current averaged distance using 10 samples
  if (isnan(currentDistance) || isnan(H_o) || isnan(H_d) || isnan(volumeConstant)) return; // Exit if required values are invalid

  rise = H_o - currentDistance;                  // Calculate dough rise from initial surface distance
  totalHeight = rise + H_d;                      // Calculate total dough height

  float target = volumeConstant * H_d;           // Calculate target height using calibration constant

  if (fabs(totalHeight - target) < 0.5) {        // Check if current height is within tolerance of target
    if (!alarmTriggered) {                       // Check if alarm has not already been triggered
      alarmTriggered = true;                     // Set alarm state to triggered

      if (!alarmEmailSent) {                     // Check if alarm email has not been sent yet
        sendRequested = true;                    // Request email sending in main loop
        alarmEmailSent = true;                   // Mark alarm email as already sent
        lastStatus = "Email queued…";            // Update email status text
      }
    }
  }
}

