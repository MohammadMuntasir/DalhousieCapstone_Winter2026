/*===/action endpoint====*/
void handleAction() {                        // Handle command requests
  if (!server.hasArg("cmd")) {              // Check if cmd argument exists
    server.send(400, "text/plain", "Missing cmd"); // Send bad request error
    return;                                  // Exit function
  }

  String cmd = server.arg("cmd");           // Read cmd argument

  if (cmd == "constBase") {                 // Handle constant base command
    H_sensor_const = readDistanceCm(100);    // Read empty container for calibration
    H_500 = NAN;                             // Reset 500 mL reading
    H_1000 = NAN;                            // Reset 1000 mL reading
    volumeConstant = NAN;                    // Reset volume constant
    server.send(200, "text/plain", isnan(H_sensor_const) ? "FAIL" : "OK"); // Send result
    return;                                  // Exit function
  }

  if (cmd == "cal500") {                    // Handle 500 mL calibration command
    if (isnan(H_sensor_const)) {             // Check if constant base was not read
      server.send(400, "text/plain", "Read constant base first"); // Send error
      return;                                // Exit function
    }
    H_500 = readDistanceCm(100);             // Read 500 mL distance
    server.send(200, "text/plain", isnan(H_500) ? "FAIL" : "OK"); // Send result
    return;                                  // Exit function
  }

  if (cmd == "cal1000") {                   // Handle 1000 mL calibration command
    if (isnan(H_sensor_const) || isnan(H_500)) { // Check if earlier calibration steps are missing
      server.send(400, "text/plain", "Do constant base + 500 mL first"); // Send error
      return;                                // Exit function
    }
    H_1000 = readDistanceCm(100);            // Read 1000 mL distance

    if (!isnan(H_1000)) {                    // Check if 1000 mL reading is valid
      float height_500 = H_sensor_const - H_500;   // Calculate 500 mL height
      float height_1000 = H_sensor_const - H_1000; // Calculate 1000 mL height
      if (height_500 != 0) {                 // Prevent division by zero
        volumeConstant = height_1000 / height_500; // Calculate constant
      }
    }

    server.send(200, "text/plain", (isnan(H_1000) || isnan(volumeConstant)) ? "FAIL" : "OK"); // Send result
    return;                                  // Exit function
  }

  if (cmd == "setConstant") {               // Handle manual constant set command
    if (!server.hasArg("value")) {          // Check if value argument exists
      server.send(400, "text/plain", "Missing value"); // Send error
      return;                                // Exit function
    }

    float val = server.arg("value").toFloat(); // Convert input value to float
    if (val <= 0) {                          // Check if constant is invalid
      server.send(400, "text/plain", "Invalid constant"); // Send error
      return;                                // Exit function
    }

    volumeConstant = val;                    // Save manual constant
    server.send(200, "text/plain", "OK");  // Send success
    return;                                  // Exit function
  }

  if (cmd == "base") {                      // Handle experiment base command
    H_sensor = readDistanceCm(100);          // Read empty container distance
    H_o = NAN;                               // Reset initial surface distance
    H_d = NAN;                               // Reset initial dough height
    rise = NAN;                              // Reset rise value
    totalHeight = NAN;                       // Reset total height
    experimentRunning = false;               // Stop experiment
    alarmTriggered = false;                  // Reset alarm flag
    alarmEmailSent = false;                  // Reset alarm email flag

    server.send(200, "text/plain", isnan(H_sensor) ? "FAIL" : "OK"); // Send result
    return;                                  // Exit function
  }

  if (cmd == "surface") {                   // Handle experiment surface command
    if (isnan(H_sensor)) {                   // Check if base was not read yet
      server.send(400, "text/plain", "Read experiment base first"); // Send error
      return;                                // Exit function
    }

    H_o = readDistanceCm(100);               // Read initial dough surface distance
    if (!isnan(H_o)) {                       // Check if reading is valid
      H_d = H_sensor - H_o;                  // Calculate initial dough height
      rise = 0;                              // Set rise to zero at start
      totalHeight = H_d;                     // Set total height to initial height
    }

    experimentRunning = false;               // Keep experiment stopped until start is pressed
    alarmTriggered = false;                  // Reset alarm flag
    alarmEmailSent = false;                  // Reset email flag

    server.send(200, "text/plain", isnan(H_o) ? "FAIL" : "OK"); // Send result
    return;                                  // Exit function
  }

  if (cmd == "start") {                     // Handle start command
    if (isnan(H_sensor) || isnan(H_o) || isnan(H_d) || isnan(volumeConstant)) { // Check required values
      server.send(400, "text/plain", "Do experiment base + surface + constant first"); // Send error
      return;                                // Exit function
    }

    alarmTriggered = false;                  // Reset alarm flag
    alarmEmailSent = false;                  // Reset alarm email flag
    experimentRunning = true;                // Start experiment
    lastUpdate = 0;                          // Force immediate update
    server.send(200, "text/plain", "OK");  // Send success
    return;                                  // Exit function
  }

  if (cmd == "stop") {                      // Handle stop command
    experimentRunning = false;               // Stop experiment
    server.send(200, "text/plain", "OK");  // Send success
    return;                                  // Exit function
  }

  if (cmd == "resetAlarm") {                // Handle reset alarm command
    alarmTriggered = false;                  // Clear alarm flag
    alarmEmailSent = false;                  // Allow future alarm email
    server.send(200, "text/plain", "OK");  // Send success
    return;                                  // Exit function
  }

  server.send(400, "text/plain", "Unknown cmd"); // Send error for unknown command
}

