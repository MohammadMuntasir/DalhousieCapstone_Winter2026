/*===Email functions=== */
void smtpCallback(SMTP_Status status) {         // Callback function after email send attempt
  if (status.success()) lastStatus = "Email sent"; // Update status if email sent successfully
  else                  lastStatus = "Email failed"; // Update status if email failed
}

bool sendEmailNow(const String& subject, const String& bodyText) { // Function to send email immediately
  if (recipientEmail.length() < 6 || recipientEmail.indexOf('@') < 1 || recipientEmail.indexOf('.') < 3) { // Validate recipient email format
    lastStatus = "Set a valid recipient email first"; // Set error message if email is invalid
    return false;                               // Return false for invalid email
  }

  session.server.host_name = SMTP_HOST;         // Set SMTP server host
  session.server.port = SMTP_PORT;              // Set SMTP server port
  session.login.email = AUTHOR_EMAIL;           // Set sender email for login
  session.login.password = AUTHOR_APP_PASS;     // Set app password for login
  session.login.user_domain = "";               // Leave user domain empty

  message.clear();                              // Clear any previous email message data
  message.sender.name = "Bread Rising Monitor"; // Set sender display name
  message.sender.email = AUTHOR_EMAIL;          // Set sender email address
  message.subject = subject;                    // Set email subject
  message.addRecipient("User", recipientEmail.c_str()); // Add recipient email

  message.text.content = bodyText.c_str();      // Set plain text email body
  message.text.charSet = "utf-8";               // Set character set to UTF-8
  message.text.transfer_encoding = Content_Transfer_Encoding::enc_7bit; // Set text encoding type

  smtp.callback(smtpCallback);                  // Register callback function for SMTP result

  if (!smtp.connect(&session)) {                // Try to connect to SMTP server
    lastStatus = "SMTP connect failed";         // Update status if connection fails
    smtp.closeSession();                        // Close SMTP session
    return false;                               // Return false if connection failed
  }

  bool ok = MailClient.sendMail(&smtp, &message); // Send email using SMTP session
  smtp.closeSession();                          // Close SMTP session after sending

  lastStatus = ok ? "Email sent" : "Send failed"; // Update final status message
  return ok;                                    // Return true or false based on send result
}

